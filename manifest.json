{
  "manifest_version": 3,
  "name": "Productivity Tracker",
  "version": "1.1",
  "description": "Track your productive and distracting time across the web.",
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "storage", "idle", "alarms", "webNavigation", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Productivity Tracker"
  }
}
